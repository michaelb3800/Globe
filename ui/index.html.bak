<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Globe Protocol - AI-to-AI Commerce</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'SF Pro', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #0a0a0f;
            color: #fff;
            overflow: hidden;
        }
        
        #globe-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
        }
        
        .header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            padding: 20px 30px;
            background: linear-gradient(180deg, rgba(10,10,15,0.9) 0%, transparent 100%);
            z-index: 10;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .logo {
            font-size: 24px;
            font-weight: 700;
            background: linear-gradient(135deg, #00d4ff 0%, #7b2ff7 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .status {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            color: #888;
        }
        
        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #00ff88;
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        .sidebar {
            position: fixed;
            right: 0;
            top: 80px;
            bottom: 0;
            width: 360px;
            background: rgba(10,10,15,0.85);
            backdrop-filter: blur(20px);
            border-left: 1px solid rgba(255,255,255,0.1);
            z-index: 10;
            padding: 20px;
            overflow-y: auto;
        }
        
        .sidebar-title {
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #666;
            margin-bottom: 16px;
        }
        
        .event-card {
            background: rgba(255,255,255,0.05);
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 12px;
            border: 1px solid rgba(255,255,255,0.08);
            transition: all 0.2s;
        }
        
        .event-card:hover {
            background: rgba(255,255,255,0.08);
            border-color: rgba(0,212,255,0.3);
        }
        
        .event-type {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #00d4ff;
            margin-bottom: 8px;
        }
        
        .event-parties {
            display: flex;
            justify-content: space-between;
            font-size: 13px;
            color: #aaa;
            margin-bottom: 8px;
        }
        
        .event-amount {
            font-size: 18px;
            font-weight: 600;
            color: #00ff88;
        }
        
        .event-time {
            font-size: 11px;
            color: #555;
            margin-top: 8px;
        }
        
        .stats {
            position: fixed;
            bottom: 30px;
            left: 30px;
            z-index: 10;
            display: flex;
            gap: 20px;
        }
        
        .stat {
            background: rgba(10,10,15,0.85);
            backdrop-filter: blur(20px);
            border-radius: 12px;
            padding: 16px 24px;
            border: 1px solid rgba(255,255,255,0.1);
        }
        
        .stat-value {
            font-size: 28px;
            font-weight: 700;
            color: #00d4ff;
        }
        
        .stat-label {
            font-size: 11px;
            text-transform: uppercase;
            color: #666;
            margin-top: 4px;
        }
        
        .loading {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #666;
            font-size: 14px;
            z-index: 100;
        }
        
        .controls {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 10;
            display: flex;
            gap: 10px;
        }
        
        .btn {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            color: #fff;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.2s;
        }
        
        .btn:hover {
            background: rgba(255,255,255,0.2);
            border-color: rgba(0,212,255,0.5);
        }
        
        .btn.active {
            background: rgba(0,212,255,0.2);
            border-color: #00d4ff;
            color: #00d4ff;
        }
    </style>
</head>
<body>
    <div id="globe-container"></div>
    
    <div class="header">
        <div class="logo">🌐 Globe Protocol</div>
        <div class="status">
            <div class="status-dot"></div>
            <span>Live</span>
        </div>
    </div>
    
    <div class="sidebar">
        <div class="sidebar-title">Recent Transactions</div>
        <div id="events-list"></div>
    </div>
    
    <div class="stats">
        <div class="stat">
            <div class="stat-value" id="tx-count">0</div>
            <div class="stat-label">Transactions</div>
        </div>
        <div class="stat">
            <div class="stat-value" id="volume">$0</div>
            <div class="stat-label">Volume</div>
        </div>
    </div>
    
    <div class="controls">
        <button class="btn active" onclick="setView('globe')">Globe</button>
        <button class="btn" onclick="setView('arcs')">Arcs</button>
        <button class="btn" onclick="refreshEvents()">Refresh</button>
    </div>
    
    <div class="loading" id="loading">Loading Globe...</div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <script>
        // ============ CONFIG ============
        const API_URL = 'http://localhost:3001';
        
        // ============ THREE.JS GLOBE ============
        let scene, camera, renderer, globe, controls;
        let arcs = [];
        let agents = [];
        
        const GLOBE_RADIUS = 100;
        const GLOBE_SEGMENTS = 64;
        
        function init() {
            // Scene
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x0a0a0f);
            
            // Camera
            camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 2000);
            camera.position.z = 350;
            
            // Renderer
            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            document.getElementById('globe-container').appendChild(renderer.domElement);
            
            // Controls
            controls = new THREE.OrbitControls(camera, renderer.domElement);
            controls.enableDamping = true;
            controls.dampingFactor = 0.05;
            controls.rotateSpeed = 0.5;
            controls.minDistance = 150;
            controls.maxDistance = 600;
            
            // Lighting
            const ambientLight = new THREE.AmbientLight(0x404040, 1.5);
            scene.add(ambientLight);
            
            const directionalLight = new THREE.DirectionalLight(0xffffff, 1);
            directionalLight.position.set(200, 200, 200);
            scene.add(directionalLight);
            
            // Create Globe
            createGlobe();
            
            // Stars background
            createStars();
            
            // Hide loading
            document.getElementById('loading').style.display = 'none';
            
            // Start animation loop
            animate();
            
            // Load initial data
            refreshEvents();
            
            // Auto-refresh every 30 seconds
            setInterval(refreshEvents, 30000);
        }
        
        function createGlobe() {
            // Globe geometry
            const geometry = new THREE.SphereGeometry(GLOBE_RADIUS, GLOBE_SEGMENTS, GLOBE_SEGMENTS);
            
            // Globe material - dark with grid
            const material = new THREE.MeshPhongMaterial({
                color: 0x1a1a2e,
                emissive: 0x0a0a1a,
                specular: 0x111111,
                shininess: 10,
                transparent: true,
                opacity: 0.9
            });
            
            globe = new THREE.Mesh(geometry, material);
            scene.add(globe);
            
            // Grid lines
            const gridHelper = new THREE.Group();
            
            // Latitude lines
            for (let lat = -60; lat <= 60; lat += 30) {
                const latRad = lat * Math.PI / 180;
                const r = GLOBE_RADIUS * Math.cos(latRad);
                const y = GLOBE_RADIUS * Math.sin(latRad);
                
                const geometry = new THREE.BufferGeometry();
                const points = [];
                for (let lon = 0; lon <= 360; lon += 5) {
                    const lonRad = lon * Math.PI / 180;
                    points.push(new THREE.Vector3(
                        r * Math.cos(lonRad),
                        y,
                        r * Math.sin(lonRad)
                    ));
                }
                geometry.setFromPoints(points);
                const material = new THREE.LineBasicMaterial({ 
                    color: 0x333355, 
                    transparent: true, 
                    opacity: 0.3 
                });
                const line = new THREE.Line(geometry, material);
                gridHelper.add(line);
            }
            
            // Longitude lines
            for (let lon = 0; lon < 360; lon += 30) {
                const lonRad = lon * Math.PI / 180;
                const geometry = new THREE.BufferGeometry();
                const points = [];
                for (let lat = -90; lat <= 90; lat += 5) {
                    const latRad = lat * Math.PI / 180;
                    points.push(new THREE.Vector3(
                        GLOBE_RADIUS * Math.cos(latRad) * Math.cos(lonRad),
                        GLOBE_RADIUS * Math.sin(latRad),
                        GLOBE_RADIUS * Math.cos(latRad) * Math.sin(lonRad)
                    ));
                }
                geometry.setFromPoints(points);
                const material = new THREE.LineBasicMaterial({ 
                    color: 0x333355, 
                    transparent: true, 
                    opacity: 0.3 
                });
                const line = new THREE.Line(geometry, material);
                gridHelper.add(line);
            }
            
            scene.add(gridHelper);
            
            // Atmosphere glow
            const atmosphereGeometry = new THREE.SphereGeometry(GLOBE_RADIUS + 5, 64, 64);
            const atmosphereMaterial = new THREE.MeshBasicMaterial({
                color: 0x00d4ff,
                transparent: true,
                opacity: 0.05,
                side: THREE.BackSide
            });
            const atmosphere = new THREE.Mesh(atmosphereGeometry, atmosphereMaterial);
            scene.add(atmosphere);
        }
        
        function createStars() {
            const starsGeometry = new THREE.BufferGeometry();
            const starCount = 2000;
            const positions = new Float32Array(starCount * 3);
            
            for (let i = 0; i < starCount * 3; i += 3) {
                const radius = 500 + Math.random() * 500;
                const theta = Math.random() * Math.PI * 2;
                const phi = Math.acos(2 * Math.random() - 1);
                
                positions[i] = radius * Math.sin(phi) * Math.cos(theta);
                positions[i + 1] = radius * Math.sin(phi) * Math.sin(theta);
                positions[i + 2] = radius * Math.cos(phi);
            }
            
            starsGeometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
            
            const starsMaterial = new THREE.PointsMaterial({
                color: 0xffffff,
                size: 1,
                transparent: true,
                opacity: 0.8
            });
            
            const stars = new THREE.Points(starsGeometry, starsMaterial);
            scene.add(stars);
        }
        
        // ============ COORDINATE CONVERSION ============
        function latLonToVector3(lat, lon, radius) {
            const phi = (90 - lat) * Math.PI / 180;
            const theta = (lon + 180) * Math.PI / 180;
            
            return new THREE.Vector3(
                -radius * Math.sin(phi) * Math.cos(theta),
                radius * Math.cos(phi),
                radius * Math.sin(phi) * Math.sin(theta)
            );
        }
        
        // ============ ARCS ============
        function createArc(lat1, lon1, lat2, lon2, color = 0x00d4ff) {
            const start = latLonToVector3(lat1, lon1, GLOBE_RADIUS + 2);
            const end = latLonToVector3(lat2, lon2, GLOBE_RADIUS + 2);
            
            // Calculate control point for curve
            const mid = start.clone().add(end).multiplyScalar(0.5);
            const length = start.distanceTo(end);
            mid.normalize().multiplyScalar(GLOBE_RADIUS + length * 0.5);
            
            // Create curve
            const curve = new THREE.QuadraticBezierCurve3(start, mid, end);
            const points = curve.getPoints(50);
            const geometry = new THREE.BufferGeometry().setFromPoints(points);
            
            const material = new THREE.LineBasicMaterial({ 
                color: color,
                transparent: true,
                opacity: 0.8
            });
            
            const line = new THREE.Line(geometry, material);
            
            // Add glow effect
            const glowMaterial = new THREE.LineBasicMaterial({ 
                color: color,
                transparent: true,
                opacity: 0.3,
                linewidth: 2
            });
            const glowLine = new THREE.Line(geometry.clone(), glowMaterial);
            
            const arcGroup = new THREE.Group();
            arcGroup.add(line);
            arcGroup.add(glowLine);
            
            return arcGroup;
        }
        
        function addAgentNode(lat, lon, agentId, reputation) {
            const position = latLonToVector3(lat, lon, GLOBE_RADIUS + 5);
            
            // Node geometry
            const geometry = new THREE.SphereGeometry(3, 16, 16);
            const color = reputation > 50 ? 0x00ff88 : 0x00d4ff;
            const material = new THREE.MeshBasicMaterial({ color: color });
            const node = new THREE.Mesh(geometry, material);
            node.position = position;
            
            // Reputation halo
            const haloGeometry = new THREE.RingGeometry(4, 6, 32);
            const haloMaterial = new THREE.MeshBasicMaterial({ 
                color: color, 
                transparent: true, 
                opacity: 0.5,
                side: THREE.DoubleSide
            });
            const halo = new THREE.Mesh(haloGeometry, haloMaterial);
            halo.position.copy(position);
            halo.lookAt(0, 0, 0);
            
            scene.add(node);
            scene.add(halo);
            
            agents.push({ node, halo, agentId });
        }
        
        // ============ API ============
        async function refreshEvents() {
            try {
                const response = await fetch(`${API_URL}/events/recent?limit=20`);
                const data = await response.json();
                
                // Clear existing arcs
                arcs.forEach(arc => scene.remove(arc));
                arcs = [];
                
                agents.forEach(agent => {
                    scene.remove(agent.node);
                    scene.remove(agent.halo);
                });
                agents = [];
                
                // Update stats
                document.getElementById('tx-count').textContent = data.events.length;
                const totalVolume = data.events.reduce((sum, e) => sum + (e.amount || 0), 0);
                document.getElementById('volume').textContent = '$' + (totalVolume / 1000000).toFixed(2) + 'M';
                
                // Render events
                const eventsList = document.getElementById('events-list');
                eventsList.innerHTML = '';
                
                data.events.forEach(event => {
                    // Add arc if we have locations
                    if (event.locationA && event.locationB) {
                        const arc = createArc(
                            event.locationA.lat,
                            event.locationA.lon,
                            event.locationB.lat,
                            event.locationB.lon,
                            0x00ff88
                        );
                        arcs.push(arc);
                        scene.add(arc);
                        
                        // Add agent nodes
                        addAgentNode(event.locationA.lat, event.locationA.lon, event.agentA, 75);
                        addAgentNode(event.locationB.lat, event.locationB.lon, event.agentB, 60);
                    }
                    
                    // Add event card
                    const card = document.createElement('div');
                    card.className = 'event-card';
                    card.innerHTML = `
                        <div class="event-type">${event.type || 'TRANSACTION'}</div>
                        <div class="event-parties">
                            <span>${event.agentA?.slice(0, 8) || '???'}...</span>
                            <span>→</span>
                            <span>${event.agentB?.slice(0, 8) || '???'}...</span>
                        </div>
                        <div class="event-amount">$${(event.amount / 1000000).toFixed(2)}</div>
                        <div class="event-time">${new Date(event.timestamp).toLocaleString()}</div>
                    `;
                    eventsList.appendChild(card);
                });
                
            } catch (error) {
                console.error('Failed to fetch events:', error);
                document.getElementById('loading').textContent = 'API unavailable - Running in demo mode';
                document.getElementById('loading').style.display = 'block';
                
                // Demo mode - show sample data
                showDemoData();
            }
        }
        
        function showDemoData() {
            // Demo transactions
            const demoEvents = [
                { type: 'ESCROW_CREATED', agentA: '0x1234...', agentB: '0x5678...', amount: 5000000 },
                { type: 'DELIVERY', agentA: '0xabcd...', agentB: '0xefgh...', amount: 2500000 },
                { type: 'RELEASED', agentA: '0x1111...', agentB: '0x2222...', amount: 10000000 },
            ];
            
            document.getElementById('tx-count').textContent = demoEvents.length;
            document.getElementById('volume').textContent = '$17.50M';
            
            const eventsList = document.getElementById('events-list');
            eventsList.innerHTML = '';
            
            demoEvents.forEach(event => {
                const card = document.createElement('div');
                card.className = 'event-card';
                card.innerHTML = `
                    <div class="event-type">${event.type}</div>
                    <div class="event-parties">
                        <span>${event.agentA}</span>
                        <span>→</span>
                        <span>${event.agentB}</span>
                    </div>
                    <div class="event-amount">$${(event.amount / 1000000).toFixed(2)}</div>
                `;
                eventsList.appendChild(card);
            });
            
            // Demo arc (SF to NYC)
            const arc = createArc(37.7749, -122.4194, 40.7128, -74.0060, 0x00ff88);
            arcs.push(arc);
            scene.add(arc);
            
            // Demo agents
            addAgentNode(37.7749, -122.4194, 'Agent A', 85);
            addAgentNode(40.7128, -74.0060, 'Agent B', 72);
        }
        
        function setView(view) {
            document.querySelectorAll('.btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            
            if (view === 'globe') {
                camera.position.z = 350;
            } else if (view === 'arcs') {
                camera.position.z = 200;
            }
        }
        
        function animate() {
            requestAnimationFrame(animate);
            controls.update();
            
            // Slow rotation
            if (globe) {
                globe.rotation.y += 0.001;
            }
            
            renderer.render(scene, camera);
        }
        
        // Handle window resize
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
        
        // Initialize
        init();
    </script>
</body>
</html>
